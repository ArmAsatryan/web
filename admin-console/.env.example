# Copy to `.env` (gitignored) to override the committed `.env.development`
# / `.env.production` defaults on your machine.
#
# Default backend (dev + prod): https://api.ballistiq.xyz
VITE_API_BASE_URL=https://api.ballistiq.xyz

# GET /api/loads/full (Server health). Token is required if your admin JWT is not valid on that host.
# Copy this file to `.env.local` and set the value (gitignored):
# VITE_LOADS_API_TOKEN=
# If the server returns 401 "cookie token empty", keep the token; the app also sends it as Cookie (name default: token)
# VITE_LOADS_COOKIE_NAME=token
