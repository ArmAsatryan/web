# Copy to `.env` (gitignored) to override the committed `.env.development`
# / `.env.production` defaults on your machine.
#
# Optional: force Adapty requests to a remote API in dev (bypasses Vite proxy / same-origin).
# If unset or localhost, `npm run dev` proxies /admin/api/adapty → Express (EXPRESS_DEV_PORT, default 3000).
# VITE_ADAPTY_API_BASE_URL=https://your-staging.example
