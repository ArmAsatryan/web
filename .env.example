# Copy to `.env` in this directory (gitignored). Use a secret from Adapty → App settings.
# If you ever pasted `secret_live_…` in chat, rotate the key in Adapty first.
ADAPTY_SECRET_API_KEY=

# Admin console: in `admin-console/.env` set so the Adapty page calls this server:
# VITE_ADAPTY_API_BASE_URL=http://localhost:3000
